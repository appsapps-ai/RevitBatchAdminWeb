@model List<RevitBatchAdminWeb.Services.UserDto>

@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <h2 class="page-title">User Management</h2>
    <p class="page-subtitle">
        Manage admin users, contract managers, and normal users.
    </p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<a href="/Users/Create" class="btn btn-primary mb-3">
    Create User
</a>

<div class="filter-bar">
    <div class="row">
        <div class="col-md-4 mb-2 mb-md-0">
            <input type="text"
                   id="userSearch"
                   class="form-control"
                   placeholder="Search username or role..." />
        </div>

        <div class="col-md-3 mb-2 mb-md-0">
            <select id="roleFilter" class="form-control">
                <option value="">All Roles</option>
                <option value="user">user</option>
                <option value="admin">admin</option>
                <option value="contract manager">contract manager</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="button" id="clearUserFilters" class="btn btn-secondary w-100">
                Clear
            </button>
        </div>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Role</th>
            <th>License Count</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            var normalizedRole = user.role?.Trim().ToLower() ?? "";
            var searchText = $"{user.username} {normalizedRole}".ToLower();

            <tr class="user-row"
                data-search="@searchText"
                data-role="@normalizedRole">

                <td>@user.id</td>

                <td>
                    <strong>@user.username</strong>
                </td>

                <td>
                    @if (normalizedRole == "admin")
                    {
                        <span class="badge bg-dark">admin</span>
                    }
                    else if (normalizedRole == "contract manager")
                    {
                        <span class="badge bg-primary">contract manager</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">user</span>
                    }
                </td>

                <td>@user.licenseCount</td>

                <td>
                    @if (normalizedRole == "contract manager")
                    {
                        <a asp-controller="Licenses"
                           asp-action="ContractManager"
                           asp-route-id="@user.id"
                           class="btn btn-info btn-sm">
                            View Licenses
                        </a>
                    }

                    @if (normalizedRole == "admin")
                    {
                        <span class="text-muted small">
                            Admin account protected
                        </span>
                    }
                    else
                    {
                        <a asp-controller="Licenses"
                           asp-action="Create"
                           asp-route-userId="@user.id"
                           class="btn btn-primary btn-sm">
                            Add License
                        </a>

                        @if (normalizedRole == "contract manager")
                        {
                            <form asp-action="Delete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.id" />
                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('WARNING: This user is a Contract Manager. Deleting this Contract Manager will permanently delete the Contract Manager account, the main CM license, and all sub-licenses under this Contract Manager. This action cannot be undone. Continue?');">
                                    Delete
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Delete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@user.id" />
                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('WARNING: This will permanently delete this user and all licenses under this user. This action cannot be undone. Continue?');">
                                    Delete
                                </button>
                            </form>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        const userSearchInput = document.getElementById("userSearch");
        const roleFilter = document.getElementById("roleFilter");
        const clearUserFilters = document.getElementById("clearUserFilters");

        function applyUserFilters() {
            const searchValue = userSearchInput.value.toLowerCase().trim();
            const roleValue = roleFilter.value;

            document.querySelectorAll(".user-row").forEach(row => {
                const rowSearch = row.dataset.search || "";
                const rowRole = row.dataset.role || "";

                const matchesSearch = rowSearch.includes(searchValue);
                const matchesRole = !roleValue || rowRole === roleValue;

                row.style.display = matchesSearch && matchesRole ? "" : "none";
            });
        }

        userSearchInput.addEventListener("input", applyUserFilters);
        roleFilter.addEventListener("change", applyUserFilters);

        clearUserFilters.addEventListener("click", function () {
            userSearchInput.value = "";
            roleFilter.value = "";
            applyUserFilters();
        });
    </script>
}