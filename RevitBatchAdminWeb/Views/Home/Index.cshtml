@{
    ViewData["Title"] = "Revit Batch SaaS";
}

<div class="landing-hero">
    <div class="landing-card">
        <h1 class="landing-title">Revit Batch SaaS</h1>

        <p class="landing-subtitle">
            Cloud-based license management for Revit Batch Processing.
            Manage users, contract managers, subscriptions, devices, and license access from one secure portal.
        </p>

        <div class="mt-4">
            <a asp-controller="Auth"
               asp-action="Login"
               class="btn btn-primary btn-lg me-2">
                Admin Login
            </a>

            <a asp-controller="ContractManager"
               asp-action="Login"
               class="btn btn-outline-primary btn-lg">
                Contract Manager Login
            </a>
        </div>
    </div>
</div>