@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h2 class="page-title">Revit Batch SaaS Admin Dashboard</h2>
    <p class="page-subtitle">
        Overview of users, licenses, active subscriptions, and contract managers.
    </p>

    <div class="d-flex align-items-center gap-2 mt-2">
        <span class="badge bg-success-subtle text-success border border-success-subtle live-refresh-badge">
            ↻ Auto refresh every 10s
        </span>

        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                onclick="window.location.reload();">
            Refresh Now
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <div class="card dashboard-card p-4">
            <h5>Total Users</h5>
            <div class="metric">@ViewBag.TotalUsers</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card dashboard-card p-4">
            <h5>Total Licenses</h5>
            <div class="metric">@ViewBag.TotalLicenses</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card dashboard-card p-4">
            <h5>Active Licenses</h5>
            <div class="metric">@ViewBag.ActiveLicenses</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card dashboard-card p-4">
            <h5>Inactive Licenses</h5>
            <div class="metric">@ViewBag.InactiveLicenses</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card dashboard-card p-4">
            <h5>Contract Managers</h5>
            <div class="metric">@ViewBag.ContractManagers</div>
        </div>
    </div>
</div>